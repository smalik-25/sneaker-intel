# Copy to .env and fill in. .env is gitignored. Missing keys -> stub mode.

# eBay Developer Program -> an application "App ID (Client ID)" for the
# production Finding API keyset. https://developer.ebay.com/
EBAY_APP_ID=

# Reddit "script" app credentials. https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=sneaker-intel/0.1 by u/your_reddit_username

# Optional overrides (comma-separated). Defaults live in ingestion/config.py.
# SNEAKER_INTEL_WATCHLIST=Air Jordan 1 High,Nike Dunk Low Panda
# SNEAKER_INTEL_SUBREDDITS=sneakers,Sneakers,SneakerMarket
